{
  "model_type": "RandomForestClassifier",
  "features": [
    "order_count",
    "days_since_last_order",
    "avg_quantity",
    "order_gap_std",
    "total_spend",
    "customer_total_orders",
    "product_popularity"
  ],
  "target": "will_reorder",
